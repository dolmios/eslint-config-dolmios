{
  "name": "eslint-config-dolmios",
  "version": "4.0.0",
  "description": "A simple ESLint config with Prettier and a couple TSConfig setups",
  "author": "Jackson Dolman <mail@dolmios.com>",
  "bugs": {
    "url": "https://github.com/dolmios/eslint-config-dolmios/issues"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.10.0",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "next": "^16.2.9",
    "prettier": "^3.9.3",
    "typescript": "^6.0.3"










    
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "files": [
    "eslint.config.js",
    "rules.js",
    "configs"
  ],
  "homepage": "https://github.com/dolmios/eslint-config-dolmios#readme",
  "keywords": [
    "config",
    "eslint",
    "linting",
    "prettier",
    "typescript"
  ],
  "license": "MIT",
  "main": "eslint.config.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dolmios/eslint-config-dolmios.git"
  },
  "scripts": {
    "lint": "eslint ./test.js",
    "lint:ts": "eslint ./test.tsx",
    "lint:all": "pnpm lint && pnpm lint:ts",
    "prettier": "prettier --write ./test.js ./test.tsx",
    "print": "eslint --print-config ./test.tsx > reference.txt",
    "print:js": "eslint --print-config ./test.js > reference-js.txt",
    "print:ts": "eslint --print-config ./test.tsx > reference-ts.txt",
    "tidy": "pnpm lint:all && pnpm prettier"
  },
  "type": "module"
}
